{
  "name": "etsy-auto-lister",
  "version": "1.0.0",
  "description": "Etsy product listing automation — import from 1688, optimize copy, list via API",
  "scripts": {
    "build": "./node_modules/.bin/tsc",
    "task:import": "npm run build && node dist/tasks/import-from-1688source.js",
    "task:optimize": "npm run build && node dist/tasks/optimize-copy.js",
    "task:auth": "npm run build && node dist/tasks/setup-auth.js",
    "task:taxonomy": "npm run build && node dist/tasks/setup-taxonomy.js"
  },
  "keywords": [
    "etsy",
    "automation",
    "dropshipping"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.5",
    "dotenv": "^16.0.0",
    "mysql2": "^3.16.3",
    "winston": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
